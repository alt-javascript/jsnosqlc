{
  "name": "@alt-javascript/jsnosqlc-localstorage",
  "version": "1.1.1",
  "description": "JSNOSLQC localStorage/sessionStorage driver — isomorphic browser storage with NoSQL semantics",
  "keywords": [
    "jsnosqlc",
    "nosql",
    "localstorage",
    "sessionstorage",
    "browser",
    "isomorphic",
    "driver"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/alt-javascript/jsnosqlc/tree/main/packages/localstorage#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/alt-javascript/jsnosqlc",
    "directory": "packages/localstorage"
  },
  "type": "module",
  "main": "index.js",
  "module": "dist/jsnosqlc-localstorage.esm.js",
  "browser": "dist/jsnosqlc-localstorage.esm.js",
  "sideEffects": [
    "./LocalStorageDriver.js"
  ],
  "exports": {
    ".": {
      "browser": "./dist/jsnosqlc-localstorage.esm.js",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "scripts": {
    "build:browser": "rollup -c",
    "test": "mocha --recursive 'test/**/*.spec.js'"
  },
  "dependencies": {
    "@alt-javascript/jsnosqlc-core": "*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "*",
    "chai": "^4.3.7",
    "mocha": "^10.2.0",
    "rollup": "*"
  },
  "author": "Craig Parravicini",
  "contributors": [
    "Claude (Anthropic)"
  ],
  "license": "MIT"
}
